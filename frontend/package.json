{
  "name": "moovup-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/dev-all.mjs",
    "dev:all": "node ../scripts/dev-all.mjs",
    "dev:vite": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vite/bin/vite.js --configLoader native",
    "dev:api": "node ../scripts/dev-api.mjs",
    "build": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vite/bin/vite.js build --configLoader native",
    "check:i18n": "node scripts/check-i18n.mjs",
    "preview": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/vite/bin/vite.js preview --configLoader native"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.2.0"
  }
}
